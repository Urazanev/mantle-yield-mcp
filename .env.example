# Optional: override the default API base URL
# MANTLE_YIELD_API_BASE_URL=https://mantle-yield.asterworks.cc

# Optional: bearer token if auth is enabled on the backend
# MANTLE_YIELD_API_TOKEN=

# Optional: backend request timeout in milliseconds
# MANTLE_YIELD_API_TIMEOUT_MS=10000

# Optional: stderr logging level
# LOG_LEVEL=silent
