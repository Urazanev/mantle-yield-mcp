{
  "name": "mantle-yield-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Separate MCP server for Mantle Yield Workspace backend",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch --import=tsx/esm --no-warnings=ExperimentalWarning src/index.ts",
    "dev:tsx": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
